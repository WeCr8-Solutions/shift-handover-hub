SUPABASE_URL=https://kgrstnbxqdmadtoankqr.supabase.co

# REQUIRED for the server to return data. All tables in this schema have
# row-level security tied to authenticated users, so the anon key returns
# 0 rows for every query. Get the service_role key from:
#   Supabase Dashboard → Project Settings → API → service_role (secret)
# NEVER commit this key or expose it to the frontend.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Fallback only — server starts but all queries return empty under RLS.
SUPABASE_ANON_KEY=your-anon-key-here
