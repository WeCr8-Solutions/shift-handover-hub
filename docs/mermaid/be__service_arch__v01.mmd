%% Service Architecture — JobLine.ai Frontend
%% Type: classDiagram
%% Shows hooks, contexts, providers, and data flow boundaries
%% Updated: 2026-03-08 — reflects performance phases 1-6

classDiagram
    class QueryClientProvider {
        +staleTime: 30s
        +gcTime: 5min
        +retry: 2
        +refetchOnWindowFocus: true
    }

    class AuthContext {
        +user: User
        +profile: Profile
        +roles: AppRole[]
        +signIn()
        +signUp()
        +signOut()
    }

    class OrgContext {
        +organization: Organization
        +organizationId: string
        +orgRole: string
        +isOrgAdmin: boolean
        +teams: Team[]
        +isLoading: boolean
        <<React Query cached 5min stale>>
    }

    class TeamContext {
        +selectedTeam: Team
        +teams: Team[]
        +setSelectedTeam()
        <<derives from OrgContext>>
    }

    class OnboardingProvider {
        +currentStep: string
        +isComplete: boolean
        +completeStep()
    }

    class DashboardErrorBoundary {
        +hasError: boolean
        +handleRetry()
        <<class-based error boundary>>
    }

    class useQueue {
        +items: QueueItem[]
        +loading: boolean
        +fetchItems()
        +createItem()
        +updateItem()
        +deleteItem()
        +reorderItem()
        <<useState + debounced realtime 500ms>>
        <<optimistic updates with rollback>>
    }

    class useStations {
        +stations: Station[]
        +loading: boolean
        +handoffRecords: HandoffRecord[]
        +shiftStats: ShiftStats
        <<React Query 30s stale + 15min poll>>
        <<realtime invalidation debounced 500ms>>
        <<refetchIntervalInBackground: false>>
    }

    class useSmartAlerts {
        +alerts: SmartAlert[]
        +isLoading: boolean
        <<React Query 60s stale + 5min poll>>
        <<single RPC compute_smart_alerts>>
        <<replaces 8 parallel client queries>>
    }

    class useHandoffRecords {
        +records: HandoffRecord[]
        +createHandoffRecord()
        +fetchRecords()
        <<React Query 30s stale + 15min poll>>
    }

    class useNCR {
        +ncrs: NCRReport[]
        +createNCR()
        +approveNCR()
        +rejectNCR()
    }

    class useTeams {
        +teams: Team[]
        +createTeam()
        +updateTeam()
        +deleteTeam()
    }

    class useSubscription {
        +subscription: Subscription
        +entitlements: Entitlements
        +isTrialing: boolean
    }

    class useERPConnector {
        +connection: ERPConnection
        +syncLogs: SyncLog[]
        +triggerSync()
        +testConnection()
    }

    class useActivityLog {
        +logActivity()
    }

    class useDataAccessLog {
        +logAccess()
        +logBulkAccess()
    }

    class useRoleArchitecture {
        +permissionMatrix
        +roleHierarchy
    }

    class useEntitlements {
        +checkFeature()
        +checkLimit()
    }

    class useMFAEnforcement {
        +requiresMFA: boolean
        +isMFAEnrolled: boolean
    }

    class useUSPersonDeclaration {
        +requiresDeclaration: boolean
        +hasDeclared: boolean
        +submitDeclaration()
    }

    %% Provider tree (top to bottom)
    QueryClientProvider <|-- AuthContext : wraps
    AuthContext <|-- OrgContext : wraps
    OrgContext <|-- TeamContext : wraps (derives data)

    %% OrgContext is the single source of org data
    OrgContext <|-- useStations : reads org from context
    OrgContext <|-- useQueue : reads org from context
    OrgContext <|-- useSmartAlerts : reads org from context
    OrgContext <|-- useEntitlements : reads org from context
    OrgContext <|-- useERPConnector : reads org from context

    %% Auth dependencies
    AuthContext <|-- useHandoffRecords : uses auth
    AuthContext <|-- useNCR : uses auth
    AuthContext <|-- useDataAccessLog : uses auth

    %% Team scoping
    TeamContext <|-- useStations : scopes by team
    TeamContext <|-- useHandoffRecords : scopes by team

    %% Audit logging
    useQueue --> useActivityLog : logs mutations
    useStations --> useActivityLog : logs mutations
    useNCR --> useActivityLog : logs mutations

    %% Billing chain
    useSubscription --> useEntitlements : provides plan
    useEntitlements --> useQueue : gates features
    useEntitlements --> useERPConnector : gates ERP

    %% Compliance
    useMFAEnforcement --> AuthContext : checks org settings
    useUSPersonDeclaration --> AuthContext : checks org settings

    %% Error boundary
    DashboardErrorBoundary --> useStations : wraps
    DashboardErrorBoundary --> useSmartAlerts : wraps
