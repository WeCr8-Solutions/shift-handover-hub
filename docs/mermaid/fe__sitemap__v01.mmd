    DASH -.->|"No auth redirect"| AUTH
    TEAMS -.->|"No auth redirect"| AUTH
    QUEUE -.->|"No auth redirect"| AUTH
    SETTINGS -.->|"No auth redirect"| AUTH

    %% App navigation (header)
    DASH <-->|"Header nav"| QUEUE
    DASH <-->|"Header nav"| TEAMS
    DASH -->|"Header nav"| SETTINGS
    DASH -->|"Header nav"| PROFILE
    DASH -->|"Header nav"| UPDATES

    %% Role gates
    DASH -->|"admin role check"| ADMIN
    DASH -->|"dev/admin role check"| TESTING

    %% Safe exits
    ADMIN -->|"Back"| DASH
    TESTING -->|"Back"| DASH
    NOTFOUND -->|"Home link"| LAND
    SETTINGS -->|"Back"| DASH
